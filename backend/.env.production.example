# Production — скопируйте в .env на сервере (без коммита секретов)

APP_ENV=production
DEBUG=false
ALLOW_DIRECT_SUBSCRIPTION_CREATE=false
SKIP_GOOGLE_ID_TOKEN_VERIFICATION=false

SECRET_KEY=CHANGE_ME_min_32_chars
DATABASE_URL=postgresql://user:pass@db-host:5432/haneat
REDIS_URL=redis://redis-host:6379/0
REDIS_ENABLED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120

API_PUBLIC_BASE_URL=https://api.haneat.app
ALLOWED_ORIGINS=https://haneat.app,https://www.haneat.app
FRONTEND_URL=https://haneat.app

GOOGLE_OAUTH_CLIENT_IDS=your-web-client-id.apps.googleusercontent.com

# Яндекс ID — https://oauth.yandex.ru (redirect: haneat://oauth/yandex)
YANDEX_OAUTH_CLIENT_ID=
YANDEX_OAUTH_CLIENT_SECRET=

SPOONACULAR_API_KEY=
OPENAI_API_KEY=
OPENAI_FOOD_SCAN_MODEL=gpt-4.1-nano
ENABLE_PRE_MODERATION=false
ENABLE_AI_MODERATION=true

YOOKASSA_ENABLED=true
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Timeweb Object Storage: ключи из панели хранилища (не из корневого .env Flutter)
S3_BUCKET=haneat-media
S3_REGION=ru-1
S3_ENDPOINT_URL=https://s3.twcstorage.ru
S3_ACCESS_KEY=
S3_SECRET_KEY=
# Пока S3 не настроен — оставьте ключи пустыми: загрузки пойдут через API
CDN_URL=https://s3.twcstorage.ru/haneat-media

FIREBASE_ENABLED=true
FIREBASE_CREDENTIALS_PATH=/etc/haneat/firebase-credentials.json
FIREBASE_PROJECT_ID=

STRIPE_ENABLED=false

# Email: регистрация, подтверждение, сброс/смена пароля
REQUIRE_EMAIL_VERIFICATION=true
AUTH_LINK_BASE_URL=haneat://auth
# Вариант A: Resend (рекомендуется с VPS — Яндекс SMTP часто даёт 535)
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_xxxx
# EMAIL_FROM=onboarding@resend.dev
# EMAIL_FROM_NAME=HAN Eat

# Вариант B: Яндекс SMTP (часто 535 с серверов — см. --probe)
# EMAIL_PROVIDER=smtp
EMAIL_SMTP_HOST=smtp.yandex.com
EMAIL_SMTP_PORT=465
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_SMTP_USE_TLS=false
EMAIL_SMTP_USE_SSL=true
EMAIL_FROM=
EMAIL_FROM_NAME=HAN Eat
